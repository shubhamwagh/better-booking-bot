# Copy to .env and fill in values. Never commit .env.
# chmod 600 .env

# Better account credentials
BETTER_USERNAME=your@email.com
BETTER_PASSWORD=yourpassword

# Payment — option A: use saved card (just CVV required each time)
CARD_CVV=123

# Payment — option B: enter full card details (leave CARD_NUMBER set to use this mode)
# CARD_NUMBER=4111111111111111
# CARD_EXPIRY=12/26
# CARD_CVV=123

# Save card for future payments after new card checkout (default: false)
# SAVE_CARD=false

# Billing address — required for new card mode (option B)
# BILLING_FIRST_NAME=John
# BILLING_LAST_NAME=Smith
# BILLING_ADDRESS1=123 High Street
# BILLING_ADDRESS2=
# BILLING_CITY=Oxford
# BILLING_POSTCODE=OX1 1AA

# Path to config.yaml (default: config.yaml in same directory)
# CONFIG_PATH=config.yaml
